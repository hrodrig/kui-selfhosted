# kui-selfhosted — template for Docker Compose. Do not commit real secrets.
#
# Recommended host layout:
#   1. export STACK_HOST_DATA=/home/kui/stack-data
#   2. mkdir -p "$STACK_HOST_DATA/kiko-data" "$STACK_HOST_DATA/kui-data"
#   3. cp run/common/.env.example "${STACK_HOST_DATA}/.env" and edit
#   4. docker compose --env-file "${STACK_HOST_DATA}/.env" \
#        -f run/docker-compose/minimal/docker-compose.yml up -d
#
# For production with Traefik (+TLS):
#   docker compose --env-file "${STACK_HOST_DATA}/.env" \
#     -f run/docker-compose/traefik/docker-compose.yml up -d
#
# Unrelated to kui-selfhosted VERSION (manifests repo semver).

# --- stack data (absolute path on servers) ---
# STACK_HOST_DATA=/home/kui/stack-data

# --- images ---
KIKO_VERSION=v0.5.0
KUI_VERSION=v0.3.2
# KIKO_IMAGE=ghcr.io/hrodrig/kiko:v0.5.0
# KUI_IMAGE=ghcr.io/hrodrig/kui:v0.3.2

# --- shared secret (kiko stats API ↔ kui) ---
KIKO_API_KEY=change-me-in-production

# --- kiko (collector) ---
KIKO_LISTEN=:8080
KIKO_PUBLIC_URL=http://localhost:8080
KIKO_LOG_LEVEL=info
KIKO_DATABASE_DRIVER=sqlite
KIKO_DATABASE_PATH=/data/kiko.db
# KIKO_ALLOWED_HOSTS=gghstats.com,kzero.dev
KIKO_BUFFER_FLUSH_INTERVAL=10
KIKO_BUFFER_CAPACITY=4096
KIKO_HOST_PORT=8080

# --- kui (dashboard UI) ---
KUI_LISTEN=:3000
KUI_LOG_LEVEL=info
KUI_DATABASE_PATH=/data/kui.db
KUI_ADMIN_EMAIL=admin@localhost
KUI_ADMIN_PASSWORD=change-me-on-first-boot
KUI_HOST_PORT=3000

# --- Traefik stack only (required when using docker-compose/traefik/) ---

# Public FQDN for kiko (tracking) and kui (dashboard), e.g.:
#   KIKO_HOSTNAME=analytics.example.com
#   KUI_HOSTNAME=kui.analytics.example.com
# KIKO_HOSTNAME=
# KUI_HOSTNAME=

# Let's Encrypt ACME email (required for TLS certificate)
# ACME_EMAIL=admin@example.com

# Salt for visitor hashing (required in production, generate with: openssl rand -hex 32)
# KIKO_VISITOR_SALT=change-me
